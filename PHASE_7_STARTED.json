  "architecture_decisions": {
    "encryption": {
      "algorithm": "AES-256-GCM",
      "rationale": "NIST approved, authenticated encryption, hardware accelerated",
      "key_management": "Worker Secrets (ENCRYPTION_KEY env var)"
    },
    "multi_tenancy": {
      "pattern": "store_id:user_id:platform KV keys",
      "isolation": "D1 queries filtered by store_id",
      "audit": "Per-store audit log separation"
    },
    "audit_logging": {
      "destination": "D1 token_audit_log table",
      "async": true,
      "fire_and_forget": "Don't block token ops on audit failures"
    },
    "token_rotation": {
      "triggers": [
        "Expiration < 24h away",
        "API usage > threshold (1000 calls)"
      ],
      "mechanism": "Platform-specific OAuth2 refresh flow"
    }
  },

