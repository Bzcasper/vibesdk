{
	"name": "listing-factory",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\"",
		"dev:frontend": "vite",
		"dev:worker": "wrangler dev",
		"build": "npm run build:frontend && npm run build:worker",
		"build:frontend": "vite build",
		"build:worker": "echo 'Worker build skipped - using wrangler deploy for production'",
		"build:worker:check": "tsc --noEmit --project tsconfig.json",
		"deploy": "wrangler deploy",
		"db:migrate": "wrangler d1 migrations apply listing-factory-db --local",
		"type-check": "tsc --noEmit",
		"lint": "eslint . --ext .ts,.tsx"
	},
