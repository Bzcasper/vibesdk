  "data_flow_example": {
    "scenario": "User uploads jewelry folder → All platforms",
    "steps": [
      "1. POST /api/dispatch/publish {listing_id, platforms: [ebay, shopify, tiktok]}",
      "2. API queues 3 jobs to appropriate queues",
      "3a. DISPATCH_QUEUE: ebay_upload job → ebay-dispatcher → CSV → Browser",
      "3b. DISPATCH_QUEUE: shopify_create_product → api-dispatcher → REST API",
      "3c. SOCIAL_QUEUE: tiktok_generate_content → content-generator → AI script",
      "4. Each job updates D1 dispatch_logs table with status",
      "5. GET /api/dispatch/status/:listing_id returns all platform statuses",
      "6. Frontend polls for updates, displays published URLs"
    ]
  },
