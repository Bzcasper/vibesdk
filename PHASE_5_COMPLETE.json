  "queue_handler_specifications": {
    "DISPATCH_QUEUE": {
      "job_types": [
        "ebay_upload",
        "shopify_create_product",
        "etsy_create_listing",
        "facebook_marketplace_post",
        "poshmark_browser_upload",
        "whatnot_browser_upload",
        "mercari_browser_upload"
      ],
      "consumer_function": "dispatchQueueHandler",
      "error_handling": "Retry with exponential backoff",
      "max_retries": 3
    },
    "SOCIAL_QUEUE": {
      "job_types": [
        "tiktok_generate_content",
        "pinterest_generate_content",
        "instagram_generate_content"
      ],
      "consumer_function": "socialQueueHandler",
      "error_handling": "Log failure, notify user",
      "max_retries": 2
    }
  },
