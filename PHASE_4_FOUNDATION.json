  "api_flow_example": {
    "user_action": "POST /api/dispatch/publish",
    "payload": {
      "listing_id": "prod-12345",
      "platforms": ["ebay", "shopify", "tiktok"]
    },
    "flow": [
      "1. API validates listing exists in D1",
      "2. Gets image assets from media_assets table",
      "3. Calls dispatchToAllPlatforms()",
      "4. Routes to platform-specific dispatchers:",
      "   - eBay → queue.send({ type: 'ebay_upload', ... })",
      "   - Shopify → queue.send({ type: 'shopify_create_product', ... })",
      "   - TikTok → queue.send({ type: 'tiktok_generate_content', ... })",
      "5. Returns 202 Accepted with job IDs",
      "6. Client polls /api/dispatch/status/:listing_id for updates"
    ]
  },
