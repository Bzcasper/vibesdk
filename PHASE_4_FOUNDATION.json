  "pipeline_architecture": {
    "stage_1": {
      "name": "Folder Upload & Ingest",
      "handler": "ListingSession DO",
      "inputs": ["images folder", "product description"],
      "outputs": ["raw_input in D1"]
    },
    "stage_2": {
      "name": "AI Enrichment",
      "handler": "enricher.ts (Phase 3)",
      "models": ["@cf/meta/llama-3.3-70b-instruct-fp8-fast"],
      "tasks": [
        "classification",
        "field_extraction",
        "field_completion",
        "title_generation (per platform)",
        "description_generation (per platform)",
        "pricing_strategy"
      ],
      "outputs": ["enriched_listing in D1"]
    },
    "stage_3": {
      "name": "Image Processing",
      "handler": "media/processor.ts",
      "tasks": [
        "validate_format",
        "remove_background (optional)",
        "generate_platform_variants (R2)"
      ],
      "outputs": ["processed_images in R2"]
    },
    "stage_4": {
      "name": "SKU Generation",
      "handler": "sku.ts (Phase 3)",
      "output": "sku (CJP-{CATEGORY}-{YYMM}-{SEQ})"
    },
    "stage_5": {
      "name": "Platform-Specific Building",
      "handlers": [
        "csv-builder.ts (eBay)",
        "shopify/listing-builder.ts (coming)",
        "etsy/listing-builder.ts (coming)"
      ],
      "outputs": ["platform_outputs in D1"]
    },
    "stage_6": {
      "name": "Multi-Platform Dispatch",
      "handler": "dispatch/index.ts",
      "output": "Queue jobs (DISPATCH_QUEUE, MEDIA_QUEUE, SOCIAL_QUEUE)"
    },
    "stage_7": {
      "name": "Async Execution",
      "handlers": [
        "ebay-uploader.ts (browser)",
        "api-dispatcher.ts (Shopify, Etsy, Facebook)",
        "social-dispatcher.ts (TikTok, Pinterest, Instagram)"
      ],
      "outputs": ["published_urls in D1"]
    }
  },
